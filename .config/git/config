[user]
  name = voidCaffeLatte
  email = void.caffelatte@gmail.com
[core]
  autocrlf = input
  editor = nvim
  fsmonitor = true
  untrackedcache = true
  pager = delta
[alias]
  st = status
  sw = switch
  pl = pull
  ps = push
  fe = fetch
  rs = restore
  re = reset
  rb = rebase
  cm = commit
  df = diff
  ds = diff --staged
  lg = log --oneline --graph
  ss = stash
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
[merge]
  conflictStyle = zdiff3
