{
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"title\":\"Claude Code\",\"message\":\"Task completed\"}' | $HOME/.claude/notification.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh"
  },
  "env": {
    "VISUAL": "nvim",
    "EDITOR": "nvim"
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
